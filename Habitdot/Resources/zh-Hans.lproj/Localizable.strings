"legal.effectiveDate" = "生效日期：2026 年 5 月 28 日";
"legal.privacy.title" = "隐私政策";
"legal.privacy.section.1.title" = "1. 概述";
"legal.privacy.section.1.body" = "Habitdot 是一款简单的习惯记录 App，可帮助你创建习惯、添加选填初衷、查看进度、使用小组件，并接收简短的动机反馈。本隐私政策说明我们会收集哪些信息、如何使用，以及你有哪些选择。";
"legal.privacy.section.2.title" = "2. 你提供的信息";
"legal.privacy.section.2.body" = "你可以输入习惯名称、选填的习惯初衷、颜色、频率设置、提醒偏好、完成记录、语言设置和外观设置。在引导流程中或联系我们时，你还可能提供问卷回答、你是如何得知 Habitdot 的，以及自由填写的反馈、联系消息或错误报告。Habitdot 不要求你创建账号，也不会为了使用核心功能而要求你的姓名、电子邮件地址、电话号码或联系人。";
"legal.privacy.section.3.title" = "3. 本地存储和小组件";
"legal.privacy.section.3.body" = "你的习惯数据主要存储在你的设备，以及 Habitdot 和其主屏幕小组件使用的 App Group 容器中。小组件会读取这些本地数据，以便在主屏幕显示你选择的习惯和进度。";
"legal.privacy.section.4.title" = "4. AI 动机反馈";
"legal.privacy.section.4.body" = "如果 AI 反馈可用或已启用，Habitdot 可能会将有限的习惯数据发送到我们的服务器，以生成简短的每日消息。这可能包括习惯标题、选填初衷、最近 7 天完成数据、昨天的完成状态、今天日期、语言地区、颜色信息和 App 安装标识符。我们使用这些数据来生成反馈消息、运营服务、防止滥用并提升可靠性。";
"legal.privacy.section.5.title" = "5. 设备和技术数据";
"legal.privacy.section.5.body" = "当 Habitdot 与我们的服务器通信时，IP 地址、请求时间、端点、响应状态，以及基本设备/网络信息等标准技术信息，可能会由我们的托管基础架构处理，用于安全、调试、分析和服务运营。";
"legal.privacy.section.6.title" = "6. 购买和订阅";
"legal.privacy.section.6.body" = "如果你购买 Habitdot Pro，购买会由 Apple 通过 App Store 处理，并可能由 RevenueCat 等第三方订阅服务管理。我们不会收到你的完整付款卡信息。我们可能会收到订阅状态、商品标识符、交易标识符，以及用于解锁 Pro 功能和恢复购买所需的相关购买元数据。";
"legal.privacy.section.7.title" = "7. 通知";
"legal.privacy.section.7.body" = "如果你启用习惯提醒，Habitdot 可能会在你的设备上安排本地通知。通知偏好用于提醒你完成习惯，可在 App 或设备设置中更改。";
"legal.privacy.section.8.title" = "8. 我们如何使用信息";
"legal.privacy.section.8.body" = "我们使用信息来提供习惯记录、显示进度、支持小组件、生成可选 AI 反馈、维护和保护 App、处理购买、恢复订阅、回复支持请求，以及遵守法律义务。";
"legal.privacy.section.9.title" = "9. 信息共享";
"legal.privacy.section.9.body" = "我们不会出售你的个人信息。我们可能会与协助运营 Habitdot 的服务提供商共享有限信息，例如托管服务提供商、AI 服务提供商、Apple，以及 RevenueCat 等订阅管理提供商。这些提供商会代表我们或依其自身条款处理信息。";
"legal.privacy.section.10.title" = "10. 数据保留和删除";
"legal.privacy.section.10.body" = "本地习惯数据会保留在你的设备上，直到你删除数据、卸载 App 或重置数据。服务器日志和 AI 服务记录可能会在安全、调试和服务运营所需的有限期间内保留。你可以在 App 中删除习惯，也可以通过设置中的联系我们提出隐私相关请求。";
"legal.privacy.section.11.title" = "11. 儿童";
"legal.privacy.section.11.body" = "Habitdot 并非面向 13 岁以下儿童。我们不会有意收集 13 岁以下儿童的个人信息。如果你认为儿童提供了个人信息，请联系我们，以便采取适当措施。";
"legal.privacy.section.12.title" = "12. 本政策变更";
"legal.privacy.section.12.body" = "我们可能不时更新本隐私政策。若有重大变更，我们会更新生效日期，并可能在 App 内或通过其他适当方式通知。";
"legal.privacy.section.13.title" = "13. 联系";
"legal.privacy.section.13.body" = "如有隐私相关问题或请求，请通过 Habitdot 设置中的联系我们与我们联系。";
"legal.terms.title" = "使用条款";
"legal.terms.section.1.title" = "1. 同意";
"legal.terms.section.1.body" = "本使用条款规范你访问和使用 Habitdot。使用 Habitdot 即表示你同意本条款。若不同意，请勿使用本 App。";
"legal.terms.section.2.title" = "2. 服务";
"legal.terms.section.2.body" = "Habitdot 帮助你创建习惯、添加选填初衷、记录完成情况、查看进度、使用主屏幕小组件，以及接收简短的动机反馈。Habitdot 是自我提升工具，不保证任何特定结果、连续记录、健康结果、生产力结果或个人成果。";
"legal.terms.section.3.title" = "3. 你的责任";
"legal.terms.section.3.body" = "你必须对输入 Habitdot 的习惯、初衷、笔记和其他信息负责。你同意不以违反法律、侵犯权利、试图干扰服务，或滥用 AI 或服务器功能的方式使用 Habitdot。";
"legal.terms.section.4.title" = "4. AI 反馈";
"legal.terms.section.4.body" = "Habitdot 可能会根据你的习惯数据提供 AI 生成的动机反馈。AI 反馈可能不准确、不完整，或不适合你的情况。它仅供一般动机用途，不属于医疗、心理健康、法律、财务或其他专业建议。";
"legal.terms.section.5.title" = "5. 健康与安全";
"legal.terms.section.5.body" = "Habitdot 不是医疗器械或医疗保健服务。在开始或改变与运动、饮食、睡眠、用药、心理健康或其他健康事项相关的习惯前，请在适当时咨询合格专业人士。";
"legal.terms.section.6.title" = "6. 订阅和购买";
"legal.terms.section.6.body" = "Habitdot 可能提供 Habitdot Pro 等付费功能。价格、方案、试用和包含功能可能随时间变化。购买会通过 Apple 使用你的 App Store 账号处理。订阅会依 Apple 的订阅规则自动续订，除非在当前周期结束前至少 24 小时取消。";
"legal.terms.section.7.title" = "7. 取消和退款";
"legal.terms.section.7.body" = "你可以在 App Store 账号设置中管理或取消订阅。退款请求由 Apple 处理，并受 Apple 政策约束。除非 Apple 提供相关机制，否则 Habitdot 无法直接发放 App Store 退款。";
"legal.terms.section.8.title" = "8. 授权";
"legal.terms.section.8.body" = "我们授予你一项有限、非独占、不可转让、可撤销的授权，允许你依本条款和 Apple App Store 规则，以个人、非商业目的使用 Habitdot。";
"legal.terms.section.9.title" = "9. 知识产权";
"legal.terms.section.9.body" = "Habitdot 包括其设计、代码、品牌、图像和内容，均由我们或授权方拥有，并受知识产权法律保护。除法律允许外，你不得复制、修改、分发、逆向工程或基于 Habitdot 创建衍生作品。";
"legal.terms.section.10.title" = "10. 可用性和变更";
"legal.terms.section.10.body" = "我们可能随时更新、修改、暂停或停止 Habitdot 的部分内容，也可能新增、移除或变更免费或付费功能。对于因设备问题、操作系统变更、网络问题、第三方服务或超出我们合理控制范围的事件造成的中断、数据丢失或服务限制，我们不承担责任。";
"legal.terms.section.11.title" = "11. 免责声明";
"legal.terms.section.11.body" = "Habitdot 按“现状”和“可用状态”提供。在法律允许的最大范围内，我们不提供关于适销性、特定用途适用性、不侵权、可用性、准确性和可靠性的保证。";
"legal.terms.section.12.title" = "12. 责任限制";
"legal.terms.section.12.body" = "在法律允许的最大范围内，对于因使用或无法使用 Habitdot 而产生的间接、附带、特殊、衍生、惩戒性或惩罚性损害，或数据、利润、商誉或其他无形损失，我们不承担责任。";
"legal.terms.section.13.title" = "13. 终止";
"legal.terms.section.13.body" = "你可以随时停止使用 Habitdot。若你违反本条款、滥用服务，或造成安全、法律或运营风险，我们可能暂停或终止你对服务器功能的访问。";
"legal.terms.section.14.title" = "14. 本条款变更";
"legal.terms.section.14.body" = "我们可能不时更新本条款。若有重大变更，我们会更新生效日期，并可能在 App 内或通过其他适当方式通知。变更后继续使用 Habitdot，即表示你接受更新后的条款。";
"legal.terms.section.15.title" = "15. 联系";
"legal.terms.section.15.body" = "如对本条款有疑问，请通过 Habitdot 设置中的联系我们与我们联系。";
